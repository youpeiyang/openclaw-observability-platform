# =============================================================================
# Doris 数据库配置
# =============================================================================
DORIS_HOST=doris
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=
DORIS_DATABASE=opsRobot

# =============================================================================
# API 服务配置
# =============================================================================
PORT=8787

# =============================================================================
# 前端配置（Docker 环境中 API 地址）
# =============================================================================
VITE_API_URL=/api

# 时区设置
TIMEZONE=Asia/Shanghai
# =============================================================================
# 前端 Mock 模式（无需数据库，用于 UI 调试）
# 启用方式：npm run dev:mock 或设置下方变量为 true 后运行 npm run dev
# =============================================================================
# VITE_MOCK=true
